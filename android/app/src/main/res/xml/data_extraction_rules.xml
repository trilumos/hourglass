<?xml version="1.0" encoding="utf-8"?>
<!-- Privacy-first (Android 12+): exclude everything from cloud backup and
     device-to-device transfer. Focus history + profile stay on-device; users
     back up manually via Settings → Your data. Pairs with allowBackup="false". -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
    </device-transfer>
</data-extraction-rules>
